---
// ViewerModal — full-screen overlay for viewer-type slots.
// Rendered once in the page, shown/hidden via JS.
// GalleryViewer and MagazineViewer are injected dynamically based on mode.
---

<div
  id="viewer-modal"
  class="viewer-modal"
  role="dialog"
  aria-modal="true"
  aria-label="Project viewer"
  hidden
>
  <div class="modal-backdrop" id="modal-backdrop"></div>

  <div class="modal-panel">
    <header class="modal-header">
      <div class="modal-title-block">
        <span id="modal-title" class="modal-title"></span>
        <span id="modal-contributor" class="modal-contributor"></span>
      </div>
      <button id="modal-close" class="modal-close" aria-label="Close viewer">✕</button>
    </header>

    <div id="modal-content" class="modal-content">
      {/* Content is injected here by JS */}
    </div>
  </div>
</div>

<style>
  .viewer-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 24px;
  }

  .viewer-modal[hidden] {
    display: none;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: var(--color-modal-bg);
    backdrop-filter: blur(2px);
    cursor: pointer;
  }

  .modal-panel {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    width: min(860px, 100%);
    height: min(640px, 85vh);
    background: #0d0000;
    border: 1px solid var(--color-card-border);
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(204, 17, 17, 0.15);
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    border-bottom: 1px solid var(--color-card-border);
    background: #180000;
    flex-shrink: 0;
    user-select: none;
  }

  .modal-title-block {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .modal-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .modal-contributor {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .modal-close {
    all: unset;
    cursor: pointer;
    font-size: 1rem;
    color: var(--color-text-muted);
    padding: 4px 8px;
    transition: color 0.1s;
  }

  .modal-close:hover {
    color: var(--color-text);
  }

  .modal-content {
    flex: 1;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
</style>

<script>
  // ViewerModal controller — listens for slot-click events and shows the modal.

  const modal = document.getElementById('viewer-modal')!;
  const backdrop = document.getElementById('modal-backdrop')!;
  const closeBtn = document.getElementById('modal-close')!;
  const titleEl = document.getElementById('modal-title')!;
  const contributorEl = document.getElementById('modal-contributor')!;
  const contentEl = document.getElementById('modal-content')!;

  function openModal(slot: Record<string, any>) {
    titleEl.textContent = slot.title ?? '';
    contributorEl.textContent = slot.contributor ?? '';

    // Inject viewer HTML based on mode
    const mode: string = slot.viewer?.mode;
    const images: string[] = slot.viewer?.content ?? [];

    if (mode === 'gallery') {
      contentEl.innerHTML = buildGalleryHTML(images, slot.title);
    } else if (mode === 'magazine') {
      contentEl.innerHTML = buildMagazineHTML(images, slot.title);
    } else {
      // TODO: add pdf mode here when PDF viewer is built
      contentEl.innerHTML = `<p style="padding:24px;color:var(--color-text-muted)">Viewer mode "${mode}" not yet supported.</p>`;
    }

    modal.removeAttribute('hidden');
    closeBtn.focus();
  }

  function closeModal() {
    modal.setAttribute('hidden', '');
    contentEl.innerHTML = '';
  }

  // Minimal inline HTML builders — avoids needing a second round-trip for viewer components.
  // These are intentionally simple; replace with richer components once design is confirmed.

  function buildGalleryHTML(images: string[], title: string): string {
    if (!images.length) return '<p style="padding:24px;color:var(--color-text-muted)">No images.</p>';
    const thumbs = images
      .map(
        (src, i) =>
          `<button class="gallery-thumb" data-src="${src}" aria-label="Image ${i + 1}">
            <img src="${src}" alt="" loading="lazy" />
          </button>`
      )
      .join('');
    return `
      <div class="gallery-viewer" style="width:100%;height:100%;overflow-y:auto;padding:24px;">
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:12px;">
          ${thumbs}
        </div>
      </div>`;
    // TODO: lightbox on thumb click
  }

  function buildMagazineHTML(spreads: string[], title: string): string {
    if (!spreads.length) return '<p style="padding:24px;color:var(--color-text-muted)">No spreads.</p>';
    const figures = spreads
      .map(
        (src, i) =>
          `<figure style="width:100%;margin:0;line-height:0;">
            <img src="${src}" alt="${title} spread ${i + 1}" loading="${i === 0 ? 'eager' : 'lazy'}" style="width:100%;height:auto;display:block;" />
          </figure>`
      )
      .join('');
    return `<div style="width:100%;height:100%;overflow-y:auto;">${figures}</div>`;
  }

  // Event wiring
  document.addEventListener('slot-click', (e: Event) => {
    const { slot } = (e as CustomEvent).detail;
    if (slot.type === 'portal' && slot.url) {
      window.open(slot.url, '_blank', 'noopener,noreferrer');
      return;
    }
    if (slot.type === 'viewer') {
      openModal(slot);
    }
  });

  backdrop.addEventListener('click', closeModal);
  closeBtn.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape' && !modal.hasAttribute('hidden')) {
      closeModal();
    }
    // TODO: arrow key nav between slots (keyboard nav not in MVP scope)
  });
</script>
