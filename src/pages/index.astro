---
import '../styles/global.css';
import DotGrid from '../components/DotGrid.astro';
import MemoryGrid from '../components/MemoryGrid.astro';
import ViewerModal from '../components/ViewerModal.astro';
import type { SlotData } from '../components/SlotCard.astro';

const slotModules = import.meta.glob<SlotData>('../content/slots/*.json', { eager: true });
const slots: SlotData[] = Object.values(slotModules);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Silkscreen:wght@400;700&display=swap" rel="stylesheet" />
    <title>ASTRO_CORP_MEMORY</title>
    <meta name="description" content="Collective portfolio." />
  </head>

  <body>
    <DotGrid />

    <main class="site-main">
      <header class="site-header">
        <h1 class="site-title">ASTRO_CORP_MEMORY</h1>

        <nav class="site-nav" aria-label="Filter by category">
          <button class="nav-tab nav-tab--active" data-filter="all">ALL</button>
          <button class="nav-tab" data-filter="print">PRINT</button>
          <button class="nav-tab" data-filter="projects">PROJECTS</button>
        </nav>
      </header>

      <MemoryGrid slots={slots} />
    </main>

    <ViewerModal />
  </body>
</html>

<style>
  .site-main {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .site-header {
    padding: 32px 24px 16px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .site-nav {
    display: flex;
    gap: 2px;
  }

  .nav-tab {
    all: unset;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: 1rem;
    letter-spacing: 0.15em;
    padding: 8px 20px;
    color: var(--color-text);
    opacity: 0.4;
    border: 1px solid transparent;
    border-radius: 2px;
    transition: opacity 0.1s, border-color 0.1s;
  }

  .nav-tab:hover {
    opacity: 0.8;
  }

  .nav-tab--active {
    opacity: 1;
    border-color: var(--color-text);
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.nav-tab');
  const cards = document.querySelectorAll<HTMLElement>('.slot-card');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const filter = tab.dataset.filter!;

      // Update active tab
      tabs.forEach((t) => t.classList.remove('nav-tab--active'));
      tab.classList.add('nav-tab--active');

      // Show/hide cards by category
      cards.forEach((card) => {
        const slot = JSON.parse(card.dataset.slot ?? '{}');
        const match = filter === 'all' || slot.category === filter;
        card.style.display = match ? '' : 'none';
      });
    });
  });
</script>
